<realm title="Dragon Wants A Cookie">
  <bot emoji=dragon x=5 y=2 solid=true>
    <requires item=cookie></requires>

    <on blocked>
      <say>Rooooar!</say>
      <emote emoji=angry></emote>
    </on>

    <on success>
      <say>Mmm. You may pass.</say>
      <emote emoji=happy></emote>
      <set solid=false></set>
    </on>
  </bot>
</realm>

<realm title="Wizard Trades A Hint For Coins">
  <bot emoji=wizard x=4 y=1>
    <requires item=gold-coin count=5></requires>

    <on blocked>
      <say>Bring me 5 gold coins.</say>
      <emote emoji=thinking></emote>
    </on>

    <on success>
      <say>Go to the spooky forest.</say>
      <emote emoji=surprised></emote>
    </on>
  </bot>
</realm>

<realm title="Guard Checks For A Pass">
  <bot emoji=guard x=7 y=3 solid=true>
    <requires item=royal-pass></requires>

    <on blocked>
      <say>No pass, no entry.</say>
      <emote emoji=angry></emote>
    </on>

    <on success>
      <say>You may enter.</say>
      <emote emoji=calm></emote>
      <set solid=false></set>
    </on>
  </bot>
</realm>

