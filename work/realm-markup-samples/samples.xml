<realm title="Broken Machine Needs A Gear">
  <item emoji=machine x=5 y=5 solid=true>
    <requires item=gear></requires>

    <on blocked>
      <say>The machine is missing a gear.</say>
      <emote emoji=confused></emote>
    </on>

    <on success>
      <say>The machine starts humming.</say>
      <emote emoji=happy></emote>
      <set solid=false></set>
    </on>
  </item>
</realm>

<realm title="Troll Wants A Riddle Answer">
  <bot emoji=troll x=6 y=2 solid=true>
    <requires flag=solved-riddle></requires>

    <on blocked>
      <say>Answer my riddle first!</say>
      <emote emoji=smirk></emote>
    </on>

    <on success>
      <say>Correct. Cross the bridge.</say>
      <set solid=false></set>
    </on>
  </bot>
</realm>

<realm title="Baker Gives Bread If You Bring Apples">
  <bot emoji=baker x=2 y=4>
    <requires item=apple count=3></requires>

    <on blocked>
      <say>I need 3 apples for baking.</say>
      <emote emoji=hopeful></emote>
    </on>

    <on success>
      <say>Lovely apples! Here is some bread.</say>
      <emote emoji=happy></emote>
    </on>
  </bot>
</realm>